<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_tip_cashout_direct.TipCashoutScreen">
        <div class="tip-cashout-screen screen h-100 d-flex flex-column bg-100">
            <div class="top-content d-flex align-items-center p-2 border-bottom bg-view">
                <button class="btn btn-secondary" t-on-click="() => this.back()">Back</button>
                <h2 class="ms-3 mb-0">Tips / Cashout</h2>
                <div class="ms-auto me-3 text-end">
                    <div class="fw-bold">Current Drawer</div>
                    <div t-esc="env.utils.formatCurrency(state.drawerBalance)"/>
                </div>
                <button class="btn btn-primary" t-on-click="() => this.loadSummary()">Refresh</button>
            </div>
            <div class="content overflow-auto p-3">
                <table class="table table-sm table-hover bg-view">
                    <thead><tr><th>Employee</th><th>Card Tips</th><th>POS Cash Tips</th><th>Declared Cash</th><th>Paid From Drawer</th><th>Remaining</th><th>Exceptions</th><th/></tr></thead>
                    <tbody>
                        <tr t-foreach="state.lines" t-as="line" t-key="line.employee_id || 'unassigned'">
                            <td t-esc="line.employee_name"/>
                            <td t-esc="env.utils.formatCurrency(line.pos_card_tips)"/>
                            <td t-esc="env.utils.formatCurrency(line.pos_cash_tips)"/>
                            <td t-esc="env.utils.formatCurrency(line.declared_cash_tips)"/>
                            <td t-esc="env.utils.formatCurrency(line.card_tips_paid_from_drawer)"/>
                            <td t-esc="env.utils.formatCurrency(line.card_tips_remaining)"/>
                            <td><span t-if="line.ambiguous_order_ids.length" class="badge text-bg-warning me-1">Mixed payment review</span><span t-if="line.mismatch_order_ids.length" class="badge text-bg-danger">Tip mismatch</span></td>
                            <td><button class="btn btn-secondary" t-att-disabled="!line.employee_id || line.card_tips_remaining &lt;= 0" t-on-click="() => this.pay(line)">Pay Card Tips</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
