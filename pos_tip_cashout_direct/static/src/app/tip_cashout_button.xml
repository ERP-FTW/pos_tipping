<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_tip_cashout_direct.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons-modal')]" position="inside">
            <button class="btn btn-secondary btn-lg py-5" t-on-click="() => this.clickTipCashout()">
                <i class="fa fa-money me-1"/> Tips / Cashout
            </button>
        </xpath>
    </t>
</templates>
